---
const jobs = [
  {
    image: "j2.png",
    company: "Cargill de Venezuela, S.R.L.",
    jobTitle: "Software Engineer",
    department: "Operations and Supply Chain Management",
    description: `
        - Collaborate with stakeholders to define and develop effective Power Platform solutions aligned with objectives.<br>
        - Analyze complex issues, identify automation opportunities, and propose creative solutions.<br>
        - Design, develop, and deploy custom applications using Power Apps to enhance efficiency.<br>
        - Automate workflows with Power Automate and integrate systems, creating Power BI dashboards for data-driven decisions.
    `,
    duration: "january 2024 - Current",
    tools: ["Power Apps", "Power Automate", "Power BI", "Python", "HTML", "CSS", "JavaScript"]
  },
  {
    image: "j3.png",
    company: "Cargill de Venezuela, S.R.L.",
    jobTitle: "Web Developer | Internship",
    department: "Food Safety, Quality and Regulatories",
    description: `
        - Coordination of requirements with the food safety teams of at all (4) locations.<br>
        - Development of applications aligned to the Quality Management System in the Power Apps platform.<br>
        - Creation of automated workflows with Power Automate.<br>
        - Design of dashboards and interactive reports using Power BI.
    `,
    duration: "march 2023 - october 2023",
    tools: ["Power Apps", "Power Automate", "Power BI"]
  }
];

const companiesPath = "/images/companies/";
---

<section class="section experience" id="experience">
  <h2>EXPERIENCE</h2>
  <div class="experience-container">
    <div class="experience-gallery" id="experience-gallery">
      {jobs.map((job) => (
        <article class="job">
          <div class="job-image-container">
            <img src={`${companiesPath + job.image}`} alt={job.company} loading="lazy" id="job-image">
          </div>
          <div class="job-content">
            <h3 id="job-company">{job.company}</h3>
            <h4 id="job-department">{job.department}</h4>
            <div class="job-details">
              <h4 id="job-jobTitle">{job.jobTitle}</h4>
              <h4 id="job-duration">{job.duration}</h4>
            </div>
            <p id="job-description"set:html={job.description}></p>
            <ul id="job-tools">
              {job.tools.map((tool) => (
                <li id={`${tool.toLowerCase()}`}>{tool}</li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
        .experience-container { width: 100%; padding: 0 100px;}
        .experience-gallery {
            flex-direction: column;
        }
        
        .experience-container {
            max-width: 1366px;
            height: 100%;
            margin: 2vh 0;
        }
        .experience-gallery {
            display: flex;
            flex-wrap: wrap;
            justify-content: space-evenly;
            align-items: center;
            height: 100%;
        }
        .job:nth-child(2n+1) {
            align-self: flex-start;
        }
        .job:nth-child(2n) {
            align-self: flex-end;
        }
            .job {
                display: flex;
                justify-content: space-between;
                margin-bottom: 32px;
                width: 900px;
            }
                .job-image-container {
                    width: 200px;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                }
                    #job-image {
                        max-width: 200px;
                        max-height: 150px;
                        border-radius: 100%;
                        object-fit: cover;
                        aspect-ratio: 1/1;
                    }
                .job-content {
                    width: 700px;
                    padding: 12px 16px;
                    border: 1px solid #3f3f3f;
                    border-radius: 24px;
                    background-color: #252A2E;
                }
                    #job-company,
                    .job-details {
                        display: flex;
                        justify-content: space-between;
                        margin: 4px 0;
                    }
                    #job-description {
                        font-size: 12pt;
                        letter-spacing: 0.4pt;
                        margin: 4px 0;
                    }
                    #job-tools {
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        margin-top: 4px;
                        & li {
                            list-style: none;
                            margin: 4px 8px;
                            padding: 4px 8px;
                            border: 1px solid #fff;
                            border-radius: 16px;
                            font-size: 11px;
                            font-weight: 600;
                        }
                    }

  /* Small devices (phones, 480px and down) */
  @media screen and (max-width:480px){
    .experience {
        display: none;
    }
  }
</style>